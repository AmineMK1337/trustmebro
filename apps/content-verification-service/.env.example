PORT=8082
KAFKA_BROKERS=localhost:9094,localhost:9095,localhost:9096
INPUT_TOPIC=content-verification.requested
OUTPUT_TOPIC=content-verification.completed

# --- Scoring thresholds ---
THRESHOLD_VERIFIED=0.7
THRESHOLD_SUSPICIOUS=0.4
THRESHOLD_CONCERN=0.5

# --- Axis weights (must sum to 1.0) ---
WEIGHT_CONTENT_AUTHENTICITY=0.35
WEIGHT_CONTEXTUAL_CONSISTENCY=0.3
WEIGHT_SOURCE_CREDIBILITY=0.35

# --- Content Authenticity scoring ---
SCORE_AUTHENTICITY_BASE=0.7
SCORE_AUTHENTICITY_TRUSTED_BOOST=0.2
SCORE_AUTHENTICITY_SUSPICIOUS_TLD_PENALTY=0.25
SCORE_AUTHENTICITY_HOMOGLYPH_PENALTY=0.3
SCORE_AUTHENTICITY_MEDIA_PENALTY=0.05

# --- Contextual Consistency scoring ---
SCORE_CONSISTENCY_BASE=0.65
SCORE_CONSISTENCY_NO_NARRATIVE=0.5
SCORE_CONSISTENCY_MISINFO_PENALTY=0.15
SCORE_CONSISTENCY_SHORT_PENALTY=0.1
SCORE_CONSISTENCY_DETAILED_BOOST=0.05
SCORE_CONSISTENCY_TRUSTED_BOOST=0.15
SCORE_CONSISTENCY_CAPS_THRESHOLD=0.5
SCORE_CONSISTENCY_CAPS_PENALTY=0.1
SCORE_CONSISTENCY_PUNCTUATION_PENALTY=0.05

# --- Source Credibility scoring ---
SCORE_CREDIBILITY_BASE=0.55
SCORE_CREDIBILITY_TRUSTED=0.92
SCORE_CREDIBILITY_SUSPICIOUS_TLD_PENALTY=0.2
SCORE_CREDIBILITY_SUBDOMAIN_PENALTY=0.1
SCORE_CREDIBILITY_HOMOGLYPH_PENALTY=0.3
SCORE_CREDIBILITY_SOCIAL_MEDIA_CAP=0.4
SCORE_CREDIBILITY_IP_PENALTY=0.25
SCORE_CREDIBILITY_LONG_URL_PENALTY=0.05

# --- Composite score factors ---
SCORE_HISTORICAL_CONTEXT_WEIGHT=0.85
SCORE_HISTORICAL_SOURCE_WEIGHT=0.15
SCORE_SYNTHETIC_FACTOR=0.9

# --- Narrative length thresholds ---
NARRATIVE_MIN_LENGTH=20
NARRATIVE_GOOD_LENGTH=50
URL_MAX_LENGTH=200

# --- Domain lists (comma-separated) ---
# TRUSTED_DOMAINS=reuters.com,apnews.com,bbc.com
# SUSPICIOUS_TLDS=.xyz,.click,.top
# MISINFO_KEYWORDS=breaking exclusive,they don't want you to know
