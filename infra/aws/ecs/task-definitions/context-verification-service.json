{
  "family": "context-verification-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::123456789012:role/trustmebro-prod-ecs-execution-role",
  "taskRoleArn": "arn:aws:iam::123456789012:role/trustmebro-prod-context-verification-service-task-role",
  "containerDefinitions": [
    {
      "name": "context-verification-service",
      "image": "123456789012.dkr.ecr.us-east-1.amazonaws.com/context-verification-service:latest",
      "essential": true,
      "readonlyRootFilesystem": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "HOSTNAME",
          "value": "0.0.0.0"
        },
        {
          "name": "NODE_ENV",
          "value": "production"
        }
      ],
      "secrets": [
        {
          "name": "GEMINI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:replace-me"
        },
        {
          "name": "IMGBB_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:replace-me"
        },
        {
          "name": "SERPAPI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:123456789012:secret:replace-me"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/trustmebro-prod/context-verification-service",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
